<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>DWF-ProyectoFase1-SpiderCoders</display-name>

    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PortalServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.PortalServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PortalServlet</servlet-name>
        <url-pattern>/portal</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GerenteGeneralServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.GerenteGeneralServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GerenteGeneralServlet</servlet-name>
        <url-pattern>/gerente-general/inicio</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GerenteSucursalServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.GerenteSucursalServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GerenteSucursalServlet</servlet-name>
        <url-pattern>/gerente-sucursal/inicio</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DependienteServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.DependienteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DependienteServlet</servlet-name>
        <url-pattern>/dependiente/inicio</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CajeroServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.CajeroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CajeroServlet</servlet-name>
        <url-pattern>/cajero/inicio</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ClienteServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.ClienteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClienteServlet</servlet-name>
        <url-pattern>/cliente/inicio</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.spidercoders.dwf.controladores.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>RolePageFilter</filter-name>
        <filter-class>com.spidercoders.dwf.controladores.RolePageFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RolePageFilter</filter-name>
        <url-pattern>/views/secure/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>Faces Servlet</servlet-name>
        <servlet-class>jakarta.faces.webapp.FacesServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>Faces Servlet</servlet-name>
        <url-pattern>*.xhtml</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.xhtml</welcome-file>
    </welcome-file-list>
</web-app>
